#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "${ROOT}"

ADMIN_SRC_PREFIX="src/Resources/app/administration/src/"
STOREFRONT_SRC_PREFIX="src/Resources/app/storefront/src/"
ADMIN_OUTPUT_DIR="src/Resources/public/administration"
STOREFRONT_OUTPUT_DIR="src/Resources/app/storefront/dist"

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

rebuild_assets() {
  if ! echo "${STAGED_FILES}" | grep -qE "^(${ADMIN_SRC_PREFIX}|${STOREFRONT_SRC_PREFIX})"; then
    return 0
  fi

  echo "JS source changes detected — building assets (admin 6.7 + 6.6, storefront once)..."
  "${ROOT}/scripts/build-assets.sh"

  git add "${ADMIN_OUTPUT_DIR}" "${STOREFRONT_OUTPUT_DIR}"

  if git diff --cached --quiet -- "${ADMIN_OUTPUT_DIR}" "${STOREFRONT_OUTPUT_DIR}"; then
    echo "Compiled assets unchanged after build."
  else
    echo "Rebuilt assets staged for commit."
  fi
}

rebuild_assets
